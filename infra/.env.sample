# Sample environment configuration for cosmos_create.py.
# Copy this file to ".env" and fill in real values:
#   cp .env.sample .env        (bash)
#   Copy-Item .env.sample .env (PowerShell)
# Never commit the real ".env" — it may contain secrets (see infra/.gitignore).

# --- Required ---------------------------------------------------------------

# Cosmos DB account endpoint URL (from the Azure portal / Deploy to Azure output).
COSMOS_ENDPOINT=https://<account-name>.documents.azure.com:443/

# --- Authentication (choose ONE) --------------------------------------------

# Option A: account key. Simple, but prefer Azure AD where possible.
# Leave empty to use Azure AD (DefaultAzureCredential, e.g. `az login`).
COSMOS_KEY=

# --- Optional (defaults shown) ----------------------------------------------

# Database name to create / use.
COSMOS_DATABASE=gaia

# Embedding dimensions for the /dataVector field (must match your embedding model).
COSMOS_VECTOR_DIMS=1536

# Provisioned throughput (RU/s) per container.
COSMOS_THROUGHPUT=400

# --- Embedding backfill (embed_worker.py) -----------------------------------

# Azure AI Foundry account endpoint hosting the text-embedding deployment.
FOUNDRY_ENDPOINT=https://<account-name>.cognitiveservices.azure.com/

# Name of the embedding deployment (azuredeploy.json default: "text-embedding").
EMBEDDING_DEPLOYMENT=text-embedding

# Vector length the model returns; must match COSMOS_VECTOR_DIMS above.
# Set to 0 for models that do not support dimension reduction (e.g. ada-002).
EMBEDDING_DIMENSIONS=1536

# Option A: Foundry/Azure OpenAI API key. Leave empty to use Azure AD
# (DefaultAzureCredential, e.g. `az login` or a managed identity).
FOUNDRY_KEY=

# Azure OpenAI REST API version (>= 2024-02-01 is required for 'dimensions').
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: GitHub token used by local/dev mode and GitHub Models flows.
GITHUB_TOKEN=

# --- Auth: sign-in providers (Google and/or GitHub) -------------------------
# Sign-in is mandatory: users must authenticate with Google or GitHub (the old
# dev name-picker was removed). Configure at least one provider below. The local
# launcher (infra/run-local.ps1) bridges the public client ids to the web app's
# VITE_* vars; the GitHub client secret stays backend-only.

# Google OAuth *Web* Client ID (looks like "<id>.apps.googleusercontent.com").
# The backend verifies Google ID tokens with it and the web shows the Google
# button. Authorized JavaScript origins MUST include http://localhost:5173.
GOOGLE_CLIENT_ID=

# GitHub OAuth App credentials (https://github.com/settings/developers).
# GITHUB_CLIENT_ID is public (bridged to the web's VITE_GITHUB_CLIENT_ID);
# GITHUB_CLIENT_SECRET is backend-only and must NEVER be exposed to the browser.
# The OAuth App's Authorization callback URL must be http://localhost:5173/.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Web search (Brave Search API) ------------------------------------------

# Subscription token for the Brave Search API. Used by Gaia's web-search applet
# (rust/src/web_search.rs) for LLM Call 1's "Web" action and injected into the
# deployed Container App as BRAVE_SEARCH_API_KEY (azuredeploy.json). Get one at
# https://brave.com/search/api/. Leave empty to run with web search disabled.
BRAVE_SEARCH_API_KEY=

# Brave Web Search endpoint. The default is the public endpoint and rarely needs
# changing.
BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search

# --- WhatsApp contacts (LLM Call 2 "send WhatsApp" action) ------------------
# The list of people Gaia may send a WhatsApp to. LLM Call 2 picks one recipient
# per turn, writes a message, and assigns an urgency score (0.00–1.00); the
# delivery API only executes messages with urgency > 0.33. The data-execution
# self-test (infra/DataExecution.ps1, tests/LLM2/DataExecutionSpec.md) reads
# these. The default contact below ships as Gaia's primary recipient.

# Default contact: name, phone (E.164), and role/description. Fill these in.
GAIA_WHATSAPP_DEFAULT_NAME=Jonty
GAIA_WHATSAPP_DEFAULT_PHONE=+27725697683
GAIA_WHATSAPP_DEFAULT_ROLE=architect of the gaia brain design

# Optional additional contacts. Semicolon-separated "Name|+phone|role" entries,
# e.g. "Blinky|+27000000000|close friend; Mom|+27111111111|family". Leave empty
# to use only the default contact above.
GAIA_WHATSAPP_CONTACTS=
