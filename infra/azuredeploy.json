{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Provisions the Gaia platform: a Cosmos DB for NoSQL account (with vector + full-text search) and database, an Azure AI Foundry account/project with the 'model-router' and a high-performance text-embedding model deployed, and a Container App (with its environment and Log Analytics workspace). The Cosmos containers are created afterwards by infra/cosmos_create.py and their /dataVector embeddings are backfilled by infra/embed_worker.py."
  },
  "parameters": {
    "accountName": {
      "type": "string",
      "defaultValue": "[concat('gaia-', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Globally unique Cosmos DB account name."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the account."
      }
    },
    "tier": {
      "type": "string",
      "defaultValue": "free",
      "allowedValues": [ "free", "hobby" ],
      "metadata": {
        "description": "Compute/throughput tier. 'free' minimises idle cost (scale-to-zero Container App, smallest model capacity); 'hobby' is a balanced always-on configuration. Note: this controls compute only — Cosmos free tier is controlled separately by 'enableFreeTier'. See infra/README.md for the full price breakdown."
      }
    },
    "enableFreeTier": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable the Cosmos DB free tier (first 1,000 RU/s + 25 GB free, one account per subscription). Decoupled from 'tier' on purpose: this flag is IMMUTABLE on an existing Cosmos account, so keep it at the account's current value when re-deploying to avoid an error. The live gaia-rg account has it ON."
      }
    },
    "gaiaMode": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Value for the GAIA_MODE env var. REQUIRED for the app to talk to Foundry and Cosmos: the LLM and Cosmos clients are disabled unless GAIA_MODE is 'dev' or 'local'. The live deployment uses 'dev'. Leave as 'dev' unless you know otherwise."
      }
    },
    "foundryApiVersion": {
      "type": "string",
      "defaultValue": "2024-10-21",
      "metadata": {
        "description": "Azure OpenAI data-plane API version the app uses (FOUNDRY_API_VERSION). Matches the live deployment."
      }
    },
    "googleClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Google OAuth web client id for sign-in (GOOGLE_CLIENT_ID). Public identifier; leave empty to disable Google sign-in."
      }
    },
    "githubClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "GitHub OAuth App client id for sign-in (GITHUB_CLIENT_ID). Public identifier; leave empty to disable GitHub sign-in. The matching client SECRET is injected separately by the CD workflow as a Container App secret."
      }
    },
    "deployAcr": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create an Azure Container Registry the CD pipeline pushes the app image to, grant the Container App's managed identity AcrPull, and wire the registry into the app. Set false to use only public images."
      }
    },
    "acrName": {
      "type": "string",
      "defaultValue": "[concat('gaiaacr', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Globally unique Azure Container Registry name (alphanumeric only). The live registry is 'gaiarobotacr'."
      }
    },
    "acrSku": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": [ "Basic", "Standard", "Premium" ],
      "metadata": {
        "description": "Container Registry SKU. 'Basic' matches the live deployment and is the cheapest."
      }
    },
    "databaseName": {
      "type": "string",
      "defaultValue": "gaia",
      "metadata": {
        "description": "Name of the SQL (NoSQL) database to create. Must match COSMOS_DATABASE."
      }
    },
    "foundryName": {
      "type": "string",
      "defaultValue": "[concat('gaia-foundry-', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Azure AI Foundry (AI Services) account name."
      }
    },
    "foundryProjectName": {
      "type": "string",
      "defaultValue": "gaia-project",
      "metadata": {
        "description": "Foundry project name created under the Foundry account."
      }
    },
    "modelRouterVersion": {
      "type": "string",
      "defaultValue": "2025-11-18",
      "metadata": {
        "description": "Version of the Azure OpenAI 'model-router' model to deploy. '2025-11-18' is the current GA version deployed in gaia-rg."
      }
    },
    "modelRouterSku": {
      "type": "string",
      "defaultValue": "auto",
      "allowedValues": [ "auto", "Standard", "GlobalStandard" ],
      "metadata": {
        "description": "SKU for the model-router deployment. Use 'auto' to pick a region-safe default (eastus -> Standard; other regions -> GlobalStandard)."
      }
    },
    "modelRouterCapacity": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Throughput capacity (in thousands of tokens per minute) for the model-router deployment. Leave at 0 to use the tier default (free=10, hobby=50)."
      }
    },
    "deployModelRouter": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy the Azure OpenAI 'model-router' chat model — the default chat model the app calls. Requires model-router quota in the chosen region. Set to false to skip it and use GitHub Models for local/dev testing instead."
      }
    },
    "containerAppName": {
      "type": "string",
      "defaultValue": "gaia-app",
      "metadata": {
        "description": "Name of the Container App."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image to run. Replace with your own image once published."
      }
    },
    "deployEmbeddingModel": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy the text-embedding model used to populate Cosmos /dataVector and power semantic search. On by default to match the live deployment; requires embedding model quota in the chosen region. Set to false to skip it."
      }
    },
    "embeddingModel": {
      "type": "string",
      "defaultValue": "text-embedding-3-large",
      "metadata": {
        "description": "Azure OpenAI text-embedding model to deploy. 'text-embedding-3-large' is the high-performance default and supports dimension reduction via 'embeddingDimensions'."
      }
    },
    "embeddingModelVersion": {
      "type": "string",
      "defaultValue": "1",
      "metadata": {
        "description": "Version of the embedding model to deploy."
      }
    },
    "embeddingSku": {
      "type": "string",
      "defaultValue": "auto",
      "allowedValues": [ "auto", "Standard", "GlobalStandard" ],
      "metadata": {
        "description": "SKU for the embedding deployment. 'auto' picks a region-safe default (eastus -> Standard; other regions -> GlobalStandard)."
      }
    },
    "embeddingCapacity": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Throughput capacity (thousands of tokens per minute) for the embedding deployment. Leave at 0 to use the tier default (free=30, hobby=120). Raise it for higher backfill throughput."
      }
    },
    "embeddingDimensions": {
      "type": "int",
      "defaultValue": 1536,
      "metadata": {
        "description": "Embedding vector length. MUST match the Cosmos /dataVector policy (COSMOS_VECTOR_DIMS, default 1536). text-embedding-3 models support reducing dimensions to this value."
      }
    },
    "braveSearchApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Brave Search API subscription token used by Gaia's web-search applet (sent as the 'X-Subscription-Token' header). Injected into the Container App as the BRAVE_SEARCH_API_KEY env var. Leave empty to deploy without web search; the app simply skips searches when it is unset."
      }
    },
    "braveSearchEndpoint": {
      "type": "string",
      "defaultValue": "https://api.search.brave.com/res/v1/web/search",
      "metadata": {
        "description": "Brave Web Search API endpoint the app calls. Injected as BRAVE_SEARCH_ENDPOINT. The default is the public Brave Search endpoint and rarely needs changing."
      }
    },
    "ciServicePrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Object ID of the CI/CD service principal (e.g. the GitHub Actions OIDC app). When set, the template grants it the Cosmos DB Built-in Data Contributor role (for the data-retrieval self-test) and Contributor on the Container Apps managed environment (so the CD pipeline's `az containerapp update --set-env-vars` can re-validate the environment link — Microsoft.App/managedEnvironments/join/action). Leave empty to skip."
      }
    }
  },
  "variables": {
    "logAnalyticsName": "[concat('gaia-logs-', uniqueString(resourceGroup().id))]",
    "containerEnvName": "[concat('gaia-env-', uniqueString(resourceGroup().id))]",
    "modelRouterDeploymentName": "model-router",
    "embeddingDeploymentName": "text-embedding",
    "acrLoginServer": "[concat(parameters('acrName'), '.azurecr.io')]",
    "acrRegistries": [
      {
        "server": "[concat(parameters('acrName'), '.azurecr.io')]",
        "identity": "system"
      }
    ],
    "acrPullRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
    "openAiUserRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]",
    "contributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b24988ac-6180-42a0-ab88-20f7382dd24c')]",
    "cosmosOperatorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '230815da-be43-4aae-9cb4-875f7bd000aa')]",
    "tierConfig": {
      "free": {
        "cpu": "[json('0.25')]",
        "memory": "0.5Gi",
        "minReplicas": 0,
        "maxReplicas": 1,
        "modelCapacity": 10,
        "embeddingCapacity": 30
      },
      "hobby": {
        "cpu": "[json('0.5')]",
        "memory": "1Gi",
        "minReplicas": 1,
        "maxReplicas": 3,
        "modelCapacity": 50,
        "embeddingCapacity": 120
      }
    },
    "selectedTier": "[variables('tierConfig')[parameters('tier')]]",
    "effectiveModelCapacity": "[if(equals(parameters('modelRouterCapacity'), 0), variables('selectedTier').modelCapacity, parameters('modelRouterCapacity'))]",
    "effectiveModelRouterSku": "[if(equals(parameters('modelRouterSku'), 'auto'), if(equals(toLower(parameters('location')), 'eastus'), 'Standard', 'GlobalStandard'), parameters('modelRouterSku'))]",
    "effectiveEmbeddingCapacity": "[if(equals(parameters('embeddingCapacity'), 0), variables('selectedTier').embeddingCapacity, parameters('embeddingCapacity'))]",
    "effectiveEmbeddingSku": "[if(equals(parameters('embeddingSku'), 'auto'), if(equals(toLower(parameters('location')), 'eastus'), 'Standard', 'GlobalStandard'), parameters('embeddingSku'))]"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-11-15",
      "name": "[parameters('accountName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": "[parameters('enableFreeTier')]",
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ],
        "capabilities": [
          { "name": "EnableNoSQLVectorSearch" },
          { "name": "EnableNoSQLFullTextSearch" }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-11-15",
      "name": "[concat(parameters('accountName'), '/', parameters('databaseName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
      ],
      "properties": {
        "resource": {
          "id": "[parameters('databaseName')]"
        }
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleAssignments",
      "apiVersion": "2024-11-15",
      "name": "[concat(parameters('accountName'), '/', guid(parameters('accountName'), parameters('ciServicePrincipalId'), 'data-contributor'))]",
      "condition": "[not(empty(parameters('ciServicePrincipalId')))]",
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlRoleDefinitions', parameters('accountName'), '00000000-0000-0000-0000-000000000002')]",
        "principalId": "[parameters('ciServicePrincipalId')]",
        "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[concat(variables('containerEnvName'), '/Microsoft.Authorization/', guid(resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName')), parameters('ciServicePrincipalId'), 'ci-env-contributor'))]",
      "condition": "[not(empty(parameters('ciServicePrincipalId')))]",
      "comments": "Grant the CI/CD service principal Contributor on the managed environment. The CD pipeline's `az containerapp update --set-env-vars` does a full PUT that re-validates the environment link, which requires Microsoft.App/managedEnvironments/join/action. Without this the OAuth-config step fails with LinkedAuthorizationFailed even though the image deploy succeeds.",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('contributorRoleId')]",
        "principalId": "[parameters('ciServicePrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleAssignments",
      "apiVersion": "2024-11-15",
      "name": "[concat(parameters('accountName'), '/', guid(parameters('accountName'), parameters('containerAppName'), 'sami-data-contributor'))]",
      "comments": "Grant the Container App's system-assigned managed identity (SAMI) the Cosmos DB Built-in Data Contributor role (read/write/delete/query + readMetadata). This is the production auth path: the app authenticates to Cosmos via its SAMI with no static token.",
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]",
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlRoleDefinitions', parameters('accountName'), '00000000-0000-0000-0000-000000000002')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[concat(parameters('accountName'), '/Microsoft.Authorization/', guid(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName')), parameters('containerAppName'), 'cosmos-operator'))]",
      "comments": "Grant the Container App's system-assigned managed identity the control-plane 'Cosmos DB Operator' role on the account. Cosmos's data plane rejects container creation for any AAD token (there is no data-plane RBAC action for it), so the app self-creates a missing container (e.g. the derived DataLakeIndex) through ARM, which this role authorizes. Cosmos DB Operator can manage databases/containers but cannot read account keys or data, keeping the grant least-privilege.",
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]",
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('cosmosOperatorRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[parameters('acrName')]",
      "condition": "[parameters('deployAcr')]",
      "comments": "Private registry the CD pipeline builds and pushes the Gaia image to. The Container App pulls from it using its managed identity (AcrPull, below).",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('acrSku')]"
      },
      "properties": {
        "adminUserEnabled": false
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[concat(parameters('acrName'), '/Microsoft.Authorization/', guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), parameters('containerAppName'), 'acrpull'))]",
      "condition": "[parameters('deployAcr')]",
      "comments": "Let the Container App's managed identity pull images from the registry (AcrPull). The bootstrap image is public, so this can be granted after the app is created without blocking the first deployment.",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('acrPullRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[concat(parameters('foundryName'), '/Microsoft.Authorization/', guid(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName')), parameters('containerAppName'), 'openai-user'))]",
      "comments": "Grant the Container App's managed identity Cognitive Services OpenAI User on the Foundry account. This is the production auth path for the model-router and embedding calls — the app mints an AAD token from its SAMI, so no FOUNDRY_API_KEY is needed.",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]",
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('openAiUserRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-04-01-preview",
      "name": "[parameters('foundryName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[parameters('foundryName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-04-01-preview",
      "name": "[concat(parameters('foundryName'), '/', parameters('foundryProjectName'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
      ],
      "properties": {}
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-04-01-preview",
      "name": "[concat(parameters('foundryName'), '/', variables('modelRouterDeploymentName'))]",
      "condition": "[parameters('deployModelRouter')]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
      ],
      "sku": {
        "name": "[variables('effectiveModelRouterSku')]",
        "capacity": "[variables('effectiveModelCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "model-router",
          "version": "[parameters('modelRouterVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-04-01-preview",
      "name": "[concat(parameters('foundryName'), '/', variables('embeddingDeploymentName'))]",
      "condition": "[parameters('deployEmbeddingModel')]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', parameters('foundryName'), variables('modelRouterDeploymentName'))]"
      ],
      "sku": {
        "name": "[variables('effectiveEmbeddingSku')]",
        "capacity": "[variables('effectiveEmbeddingCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('embeddingModel')]",
          "version": "[parameters('embeddingModelVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerEnvName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2023-09-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 80,
            "transport": "auto"
          },
          "registries": "[if(parameters('deployAcr'), variables('acrRegistries'), json('[]'))]"
        },
        "template": {
          "containers": [
            {
              "name": "[parameters('containerAppName')]",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[variables('selectedTier').cpu]",
                "memory": "[variables('selectedTier').memory]"
              },
              "env": [
                {
                  "name": "COSMOS_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))).documentEndpoint]"
                },
                {
                  "name": "COSMOS_DATABASE",
                  "value": "[parameters('databaseName')]"
                },
                {
                  "name": "COSMOS_ACCOUNT_RESOURCE_ID",
                  "value": "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
                },
                {
                  "name": "FOUNDRY_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))).endpoint]"
                },
                {
                  "name": "MODEL_ROUTER_DEPLOYMENT",
                  "value": "[if(parameters('deployModelRouter'), variables('modelRouterDeploymentName'), '')]"
                },
                {
                  "name": "EMBEDDING_DEPLOYMENT",
                  "value": "[if(parameters('deployEmbeddingModel'), variables('embeddingDeploymentName'), '')]"
                },
                {
                  "name": "EMBEDDING_DIMENSIONS",
                  "value": "[string(parameters('embeddingDimensions'))]"
                },
                {
                  "name": "BRAVE_SEARCH_ENDPOINT",
                  "value": "[parameters('braveSearchEndpoint')]"
                },
                {
                  "name": "BRAVE_SEARCH_API_KEY",
                  "value": "[parameters('braveSearchApiKey')]"
                },
                {
                  "name": "GAIA_MODE",
                  "value": "[parameters('gaiaMode')]"
                },
                {
                  "name": "GAIA_HTTP_PORT",
                  "value": "80"
                },
                {
                  "name": "FOUNDRY_API_VERSION",
                  "value": "[parameters('foundryApiVersion')]"
                },
                {
                  "name": "GOOGLE_CLIENT_ID",
                  "value": "[parameters('googleClientId')]"
                },
                {
                  "name": "GITHUB_CLIENT_ID",
                  "value": "[parameters('githubClientId')]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[variables('selectedTier').minReplicas]",
            "maxReplicas": "[variables('selectedTier').maxReplicas]"
          }
        }
      }
    }
  ],
  "outputs": {
    "tier": {
      "type": "string",
      "value": "[parameters('tier')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))).documentEndpoint]"
    },
    "accountName": {
      "type": "string",
      "value": "[parameters('accountName')]"
    },
    "databaseName": {
      "type": "string",
      "value": "[parameters('databaseName')]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))).endpoint]"
    },
    "modelRouterDeployment": {
      "type": "string",
      "value": "[if(parameters('deployModelRouter'), variables('modelRouterDeploymentName'), '')]"
    },
    "embeddingDeployment": {
      "type": "string",
      "value": "[if(parameters('deployEmbeddingModel'), variables('embeddingDeploymentName'), '')]"
    },
    "embeddingDimensions": {
      "type": "int",
      "value": "[parameters('embeddingDimensions')]"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName'))).configuration.ingress.fqdn]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[if(parameters('deployAcr'), variables('acrLoginServer'), '')]"
    }
  }
}
