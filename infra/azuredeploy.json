{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Provisions the Gaia platform: a Cosmos DB for NoSQL account (with vector + full-text search) and database, an Azure AI Foundry account/project with the 'model-router' and a high-performance text-embedding model deployed, and a Container App (with its environment and Log Analytics workspace). The Cosmos containers are created afterwards by infra/cosmos_create.py and their /dataVector embeddings are backfilled by infra/embed_worker.py."
  },
  "parameters": {
    "accountName": {
      "type": "string",
      "defaultValue": "[concat('gaia-', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Globally unique Cosmos DB account name."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the account."
      }
    },
    "tier": {
      "type": "string",
      "defaultValue": "free",
      "allowedValues": [ "free", "hobby" ],
      "metadata": {
        "description": "Cost tier. 'free' minimises idle cost (Cosmos free tier, scale-to-zero Container App, smallest model capacity); 'hobby' is a balanced always-on configuration. See infra/README.md for the full price breakdown."
      }
    },
    "databaseName": {
      "type": "string",
      "defaultValue": "gaia",
      "metadata": {
        "description": "Name of the SQL (NoSQL) database to create. Must match COSMOS_DATABASE."
      }
    },
    "foundryName": {
      "type": "string",
      "defaultValue": "[concat('gaia-foundry-', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Azure AI Foundry (AI Services) account name."
      }
    },
    "foundryProjectName": {
      "type": "string",
      "defaultValue": "gaia-project",
      "metadata": {
        "description": "Foundry project name created under the Foundry account."
      }
    },
    "modelRouterVersion": {
      "type": "string",
      "defaultValue": "2025-05-19",
      "metadata": {
        "description": "Version of the Azure OpenAI 'model-router' model to deploy."
      }
    },
    "modelRouterSku": {
      "type": "string",
      "defaultValue": "auto",
      "allowedValues": [ "auto", "Standard", "GlobalStandard" ],
      "metadata": {
        "description": "SKU for the model-router deployment. Use 'auto' to pick a region-safe default (eastus -> Standard; other regions -> GlobalStandard)."
      }
    },
    "modelRouterCapacity": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Throughput capacity (in thousands of tokens per minute) for the model-router deployment. Leave at 0 to use the tier default (free=10, hobby=50)."
      }
    },
    "deployModelRouter": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set to true only when you have the required model quota. For testing, leave this false and use GitHub Models instead."
      }
    },
    "containerAppName": {
      "type": "string",
      "defaultValue": "gaia-app",
      "metadata": {
        "description": "Name of the Container App."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image to run. Replace with your own image once published."
      }
    },
    "deployEmbeddingModel": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set to true to deploy the text-embedding model used to populate Cosmos /dataVector. Requires embedding model quota in the chosen region."
      }
    },
    "embeddingModel": {
      "type": "string",
      "defaultValue": "text-embedding-3-large",
      "metadata": {
        "description": "Azure OpenAI text-embedding model to deploy. 'text-embedding-3-large' is the high-performance default and supports dimension reduction via 'embeddingDimensions'."
      }
    },
    "embeddingModelVersion": {
      "type": "string",
      "defaultValue": "1",
      "metadata": {
        "description": "Version of the embedding model to deploy."
      }
    },
    "embeddingSku": {
      "type": "string",
      "defaultValue": "auto",
      "allowedValues": [ "auto", "Standard", "GlobalStandard" ],
      "metadata": {
        "description": "SKU for the embedding deployment. 'auto' picks a region-safe default (eastus -> Standard; other regions -> GlobalStandard)."
      }
    },
    "embeddingCapacity": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Throughput capacity (thousands of tokens per minute) for the embedding deployment. Leave at 0 to use the tier default (free=30, hobby=120). Raise it for higher backfill throughput."
      }
    },
    "embeddingDimensions": {
      "type": "int",
      "defaultValue": 1536,
      "metadata": {
        "description": "Embedding vector length. MUST match the Cosmos /dataVector policy (COSMOS_VECTOR_DIMS, default 1536). text-embedding-3 models support reducing dimensions to this value."
      }
    }
  },
  "variables": {
    "logAnalyticsName": "[concat('gaia-logs-', uniqueString(resourceGroup().id))]",
    "containerEnvName": "[concat('gaia-env-', uniqueString(resourceGroup().id))]",
    "modelRouterDeploymentName": "model-router",
    "embeddingDeploymentName": "text-embedding",
    "tierConfig": {
      "free": {
        "cpu": "[json('0.25')]",
        "memory": "0.5Gi",
        "minReplicas": 0,
        "maxReplicas": 1,
        "modelCapacity": 10,
        "embeddingCapacity": 30,
        "enableFreeTier": true
      },
      "hobby": {
        "cpu": "[json('0.5')]",
        "memory": "1Gi",
        "minReplicas": 1,
        "maxReplicas": 3,
        "modelCapacity": 50,
        "embeddingCapacity": 120,
        "enableFreeTier": false
      }
    },
    "selectedTier": "[variables('tierConfig')[parameters('tier')]]",
    "effectiveModelCapacity": "[if(equals(parameters('modelRouterCapacity'), 0), variables('selectedTier').modelCapacity, parameters('modelRouterCapacity'))]",
    "effectiveModelRouterSku": "[if(equals(parameters('modelRouterSku'), 'auto'), if(equals(toLower(parameters('location')), 'eastus'), 'Standard', 'GlobalStandard'), parameters('modelRouterSku'))]",
    "effectiveEmbeddingCapacity": "[if(equals(parameters('embeddingCapacity'), 0), variables('selectedTier').embeddingCapacity, parameters('embeddingCapacity'))]",
    "effectiveEmbeddingSku": "[if(equals(parameters('embeddingSku'), 'auto'), if(equals(toLower(parameters('location')), 'eastus'), 'Standard', 'GlobalStandard'), parameters('embeddingSku'))]"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-11-15",
      "name": "[parameters('accountName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": "[variables('selectedTier').enableFreeTier]",
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ],
        "capabilities": [
          { "name": "EnableNoSQLVectorSearch" },
          { "name": "EnableNoSQLFullTextSearch" }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-11-15",
      "name": "[concat(parameters('accountName'), '/', parameters('databaseName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
      ],
      "properties": {
        "resource": {
          "id": "[parameters('databaseName')]"
        }
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-04-01-preview",
      "name": "[parameters('foundryName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[parameters('foundryName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-04-01-preview",
      "name": "[concat(parameters('foundryName'), '/', parameters('foundryProjectName'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
      ],
      "properties": {}
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-04-01-preview",
      "name": "[concat(parameters('foundryName'), '/', variables('modelRouterDeploymentName'))]",
      "condition": "[parameters('deployModelRouter')]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]"
      ],
      "sku": {
        "name": "[variables('effectiveModelRouterSku')]",
        "capacity": "[variables('effectiveModelCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "model-router",
          "version": "[parameters('modelRouterVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-04-01-preview",
      "name": "[concat(parameters('foundryName'), '/', variables('embeddingDeploymentName'))]",
      "condition": "[parameters('deployEmbeddingModel')]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', parameters('foundryName'), variables('modelRouterDeploymentName'))]"
      ],
      "sku": {
        "name": "[variables('effectiveEmbeddingSku')]",
        "capacity": "[variables('effectiveEmbeddingCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('embeddingModel')]",
          "version": "[parameters('embeddingModelVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerEnvName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2023-09-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 80,
            "transport": "auto"
          }
        },
        "template": {
          "containers": [
            {
              "name": "[parameters('containerAppName')]",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[variables('selectedTier').cpu]",
                "memory": "[variables('selectedTier').memory]"
              },
              "env": [
                {
                  "name": "COSMOS_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))).documentEndpoint]"
                },
                {
                  "name": "COSMOS_DATABASE",
                  "value": "[parameters('databaseName')]"
                },
                {
                  "name": "FOUNDRY_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))).endpoint]"
                },
                {
                  "name": "MODEL_ROUTER_DEPLOYMENT",
                  "value": "[if(parameters('deployModelRouter'), variables('modelRouterDeploymentName'), '')]"
                },
                {
                  "name": "EMBEDDING_DEPLOYMENT",
                  "value": "[if(parameters('deployEmbeddingModel'), variables('embeddingDeploymentName'), '')]"
                },
                {
                  "name": "EMBEDDING_DIMENSIONS",
                  "value": "[string(parameters('embeddingDimensions'))]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[variables('selectedTier').minReplicas]",
            "maxReplicas": "[variables('selectedTier').maxReplicas]"
          }
        }
      }
    }
  ],
  "outputs": {
    "tier": {
      "type": "string",
      "value": "[parameters('tier')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))).documentEndpoint]"
    },
    "accountName": {
      "type": "string",
      "value": "[parameters('accountName')]"
    },
    "databaseName": {
      "type": "string",
      "value": "[parameters('databaseName')]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))).endpoint]"
    },
    "modelRouterDeployment": {
      "type": "string",
      "value": "[if(parameters('deployModelRouter'), variables('modelRouterDeploymentName'), '')]"
    },
    "embeddingDeployment": {
      "type": "string",
      "value": "[if(parameters('deployEmbeddingModel'), variables('embeddingDeploymentName'), '')]"
    },
    "embeddingDimensions": {
      "type": "int",
      "value": "[parameters('embeddingDimensions')]"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName'))).configuration.ingress.fqdn]"
    }
  }
}
