{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys the Gaia platform at the HOBBY tier: a balanced Container App (0.5 vCPU / 1 GiB, 1-3 replicas) and a mid-size model-router capacity (50). Good default for small production workloads. This wrapper nests infra/azuredeploy.json and pins tier='hobby'."
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image to run. Replace with your own image once published."
      }
    },
    "deployEmbeddingModel": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set to true to also deploy the text-embedding model (requires embedding model quota)."
      }
    },
    "braveSearchApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Brave Search API subscription token for Gaia's web-search applet. Passed through to the Container App as BRAVE_SEARCH_API_KEY. Leave empty to deploy without web search."
      }
    }
  },
  "variables": {
    "baseTemplateUri": "https://raw.githubusercontent.com/threadkeeper/gaia-robot/main/infra/azuredeploy.json"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "gaia-hobby",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[variables('baseTemplateUri')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "tier": { "value": "hobby" },
          "location": { "value": "[parameters('location')]" },
          "containerImage": { "value": "[parameters('containerImage')]" },
          "deployEmbeddingModel": { "value": "[parameters('deployEmbeddingModel')]" },
          "braveSearchApiKey": { "value": "[parameters('braveSearchApiKey')]" }
        }
      }
    }
  ],
  "outputs": {
    "tier": {
      "type": "string",
      "value": "[reference('gaia-hobby').outputs.tier.value]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference('gaia-hobby').outputs.cosmosEndpoint.value]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference('gaia-hobby').outputs.foundryEndpoint.value]"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference('gaia-hobby').outputs.containerAppFqdn.value]"
    }
  }
}
