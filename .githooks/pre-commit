#!/usr/bin/env sh
# Pre-commit hook: runs the fast quality gate locally before each commit.
#
# Enable it once per clone with:
#   git config core.hooksPath .githooks
#
# This mirrors the CI "quality" job but keeps it fast: formatting, linting,
# and tests. The slower supply-chain audit and coverage checks run in CI.

set -e

# All Cargo commands run inside the rust/ folder where the project lives.
cd "$(git rev-parse --show-toplevel)/rust"

echo "pre-commit: checking formatting..."
cargo fmt --all -- --check

echo "pre-commit: running clippy (warnings = errors)..."
cargo clippy --all-targets --all-features -- -D warnings

echo "pre-commit: running tests..."
cargo test --all-features

echo "pre-commit: all checks passed."
