# --- Gaia PWA configuration ---------------------------------------------------
# Copy to `.env` for local development. All client-exposed vars MUST be prefixed
# VITE_ (SvelteKit only inlines those into the browser bundle).

# Base URL of the Gaia API. Leave empty to use same-origin (production behind
# Front Door) or the Vite dev proxy. Example: https://gaia.<region>.azurecontainerapps.io
VITE_API_BASE=

# Where the Vite dev server proxies /v1, /healthz, /readyz to (Rust backend).
VITE_API_PROXY=http://localhost:8080

# Reply transport: "ws" (default, streams over a WebSocket) or "post" (single
# non-streaming POST).
VITE_STREAM_TRANSPORT=ws

# --- Auth: direct Google sign-in ------------------------------------------------
# When unset, the app runs in dev mode and sends a plain subject as the bearer
# token (the backend accepts `Authorization: Bearer <sub>` for local use).
# For production, set the Google OAuth Web Client ID from Google Cloud Console.
# Authorized JavaScript origins must include your app origin and localhost:5173.
VITE_GOOGLE_CLIENT_ID=
