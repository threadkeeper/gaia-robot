# --- Gaia PWA configuration ---------------------------------------------------
# Copy to `.env` for local development. All client-exposed vars MUST be prefixed
# VITE_ (SvelteKit only inlines those into the browser bundle).

# Base URL of the Gaia API. Leave empty to use same-origin (production behind
# Front Door) or the Vite dev proxy. Example: https://gaia.<region>.azurecontainerapps.io
VITE_API_BASE=

# Where the Vite dev server proxies /v1, /healthz, /readyz to (Rust backend).
VITE_API_PROXY=http://localhost:8080

# Reply transport: "ws" (default, streams over a WebSocket) or "post" (single
# non-streaming POST).
VITE_STREAM_TRANSPORT=ws

# --- Auth: sign-in providers ----------------------------------------------------
# Sign-in is mandatory: users must authenticate with Google or GitHub. Configure
# at least one provider below, otherwise the app cannot be used.

# Google OAuth Web Client ID (Google Cloud Console). Authorized JavaScript
# origins must include your app origin and http://localhost:5173.
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth App client id (https://github.com/settings/developers). The
# Authorization callback URL must match your app origin (e.g. http://localhost:5173).
# NOTE: the matching client *secret* is server-side only — set GITHUB_CLIENT_ID
# and GITHUB_CLIENT_SECRET in the Rust backend's environment. Never expose the
# secret to the browser (do not prefix it with VITE_).
VITE_GITHUB_CLIENT_ID=
